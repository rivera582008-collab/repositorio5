Algoritmo NumerosContiuamente
	Definir suma, numero, resultado Como Entero
	suma = 0

	Repetir
		Escribir "Ingrese un número"
		Leer numero
		si numero >= 0
		suma <- suma + numero
	FinSi
	
	Hasta Que numero < 0

	resultado = suma
	Escribir " La suma de los número positivos es:",resultado
	
	
	
	
	
	
	
	
	
FinAlgoritmo
